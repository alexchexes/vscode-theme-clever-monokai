{
  "name": "clever-monokai",
  "displayName": "Clever Monokai",
  "description": "A fixed Monokai with richer semantics.",
  "version": "0.9.0",
  "publisher": "AlexChexes",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexchexes/vscode-theme-clever-monokai.git"
  },
  "type": "module",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "monokai",
    "dark theme",
    "semantic highlighting"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Clever Monokai",
        "uiTheme": "vs-dark",
        "path": "./themes/clever-monokai-color-theme.json"
      }
    ]
  },
  "scripts": {
    "build": "node scripts/build-theme.ts",
    "check": "tsc --noEmit",
    "package": "npm run build && vsce package --no-dependencies",
    "publish": "npm run build && vsce publish"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@vscode/vsce": "^3.9.2",
    "jsonc-parser": "^3.3.1",
    "typescript": "^6.0.3"
  }
}
